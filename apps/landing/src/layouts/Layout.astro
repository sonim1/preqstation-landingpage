---
import '../styles/global.css'

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  locale?: string;
}

const {
  title = "PREQSTATION — AI Agent Execution Platform",
  description = "Queue a task, let agents plan and execute it, then verify the result. An open-source, self-hosted AI agent execution platform.",
  lang = "en",
  locale = "en",
} = Astro.props;

const siteOrigin = "https://preqstation.com";
const pathname = Astro.url.pathname;
const canonicalUrl = new URL(pathname, siteOrigin).toString();
const alternateLinks =
  pathname === "/" || pathname === "/ko/"
    ? [
        { hreflang: "en", href: new URL("/", siteOrigin).toString() },
        { hreflang: "ko", href: new URL("/ko/", siteOrigin).toString() },
        { hreflang: "x-default", href: new URL("/", siteOrigin).toString() },
      ]
    : [];

const schemaDescription = locale === "ko"
  ? "AI 에이전트 실행 플랫폼 - 태스크를 큐에 넣고, 에이전트가 계획과 구현을 수행한 뒤, Ready에서 검증하고 Done으로 완료합니다."
  : "AI Agent Execution Platform - Queue tasks, let agents plan and execute, then verify in Ready before Done.";

const schemaFeatures = locale === "ko"
  ? ["워크플로우와 run_state 분리", "멀티 AI 에이전트 (Claude, Codex, Gemini)", "Claude direct dispatch 및 Telegram/OpenClaw 레거시 릴레이", "Self-hosted 오픈소스"]
  : ["Workflow and run-state separation", "Multi AI Agent (Claude, Codex, Gemini)", "Claude direct dispatch plus Telegram/OpenClaw legacy relays", "Self-hosted Open Source"];
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/webp" href="/favicon.webp" />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="512x452" />
    <link rel="shortcut icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={locale === "ko" ? "ko_KR" : "en_US"} />

    <!-- Alternate languages -->
    {alternateLinks.map((link) => (
      <link rel="alternate" hreflang={link.hreflang} href={link.href} />
    ))}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Noto+Sans+KR:wght@400;500;700;800&family=Outfit:wght@600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />

    <title>{title}</title>

    <!-- JSON-LD Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "PREQSTATION",
      "applicationCategory": "DeveloperApplication",
      "description": schemaDescription,
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "operatingSystem": "Cross-platform",
      "featureList": schemaFeatures,
    })} />
  </head>
  <body class="bg-charcoal text-white font-body antialiased overflow-x-hidden">
    <slot />
  </body>
</html>
